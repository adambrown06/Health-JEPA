# --- Root monorepo ---

# Python / backend
backend/**/__pycache__/
backend/**/*.py[cod]
backend/.env
backend/.venv/
backend/venv/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Nested git backup (legacy frontend-only repo)
.git_frontend_backup/

# Frontend — dependencies & build (see also frontend/.gitignore)
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/coverage/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Legacy root-level Next paths (if present from old layout)
/node_modules/
/.next/
/out/
/build/
.vercel/
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.env*
