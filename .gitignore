# --- Root monorepo ---

# Python / backend
backend/**/__pycache__/
backend/**/*.py[cod]
backend/.env
backend/.venv/
backend/venv/
backend/*.egg-info/
backend/.pytest_cache/
backend/.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Backup of nested git (see migration note in README if present)
.git_frontend_backup/

# Frontend (see frontend/.gitignore for Next.js specifics)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
